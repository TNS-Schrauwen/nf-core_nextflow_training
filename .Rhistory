library(data.table)
library(dplyr)
sig <- read.csv("trimmed_means.csv", row.names = 1, check.names = FALSE)
library(data.table)
sig <- fread("trimmed_means.csv")
cell_types <- colnames(sig)[-1]
for (ct in cell_types) {
# Create a matrix of zeros
pheno <- matrix(0, nrow = length(cell_types), ncol = length(cell_types))
rownames(pheno) <- cell_types
colnames(pheno) <- cell_types
# Set 2 for the comparison class (current cell type)
pheno[ct, ct] <- 2
# Set 1 for membership in their own class
for (i in cell_types) {
if (i != ct) {
pheno[i, i] <- 1
}
}
